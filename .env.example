# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gpa_user:CHANGE_ME@localhost:5432/gpa_erp
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# ─── JWT ─────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
SESSION_COOKIE_SAMESITE=lax

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=GPA-ERP
APP_VERSION=5.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000
WEB_CONCURRENCY=1

# ─── Super-Admin seed ────────────────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@gpa.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=System Administrator

# ─── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Payroll statutory parameters (update when an official ceiling changes)
BPJS_JP_SALARY_CEILING=10547400
BPJS_KES_SALARY_CEILING=12000000
BPJS_JKK_RATE=0.0089

# SMTP email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=GPA ERP <noreply@gpa.local>
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=15
EMAIL_OUTBOX_POLL_SECONDS=5
